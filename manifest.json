{
  "manifest_version": 3,
  "name": "Jira Ticket Copier",
  "version": "1.0",
  "description": "Adds a copy button to Jira ticket pages.",
  "permissions": ["clipboardWrite"],
  "content_scripts": [
    {
      "matches": [
        "*://*.atlassian.net/browse/*",
        "*://*.atlassian.net/jira/software/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["*://*.atlassian.net/*"]
}
